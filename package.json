{
  "name": "queryable-array",
  "version": "1.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/queryable-array.cjs",
  "module": "./dist/queryable-array.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/queryable-array.mjs",
