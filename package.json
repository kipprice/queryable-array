  },
  "bugs": {
    "url": "https://github.com/kipprice/queryable-array/issues"
  },
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
